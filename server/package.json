{
  "name": "atu-gps-forwarder-server",
  "version": "1.0.0",
  "description": "ATU GPS WebSocket Forwarder — Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --testPathIgnorePatterns=tests/integration",
    "test:integration": "jest --runInBand tests/integration/forwarder.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=tests/integration"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "ws": "^8.14.2",
    "node-cron": "^3.0.3",
    "dotenv": "^16.3.1",
    "nanoid": "^3.3.7",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/node-cron": "^3.0.11",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  }
}
