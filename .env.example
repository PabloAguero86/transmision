# ATU GPS Forwarder — Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION MODE
# =============================================================================
# Environment: testing | production
ATU_ENV=production

# =============================================================================
# ATU WEBSOCKET CONFIGURATION
# =============================================================================
# ATU WebSocket endpoint URL
ATU_WS_ENDPOINT=CHANGE_ME_ATU_WS_ENDPOINT

# JWT token for ATU authentication (masked in logs)
ATU_TOKEN=CHANGE_ME_ATU_TOKEN

# Maximum interval between position updates (seconds)
# If a vehicle doesn't send an update within this time, it's considered stale
ATU_MAX_UPDATE_INTERVAL_SECONDS=20

# Maximum age of a position before it's considered expired (minutes)
ATU_MAX_POSITION_AGE_MINUTES=10

# Reconnection delay after WebSocket disconnect (seconds)
ATU_RECONNECT_SECONDS=5

# Maximum reconnection attempts before giving up
ATU_MAX_RETRIES=5

# Dry run mode - don't actually send to ATU
ATU_DRY_RUN=false

# =============================================================================
# GPS SOURCE CONFIGURATION
# =============================================================================
# GPS data source type
GPS_SOURCE_TYPE=database

# How often to poll for new positions (milliseconds)
GPS_SOURCE_POLL_INTERVAL_MS=5000

# Speed unit for calculations
GPS_SPEED_UNIT=km/h

# =============================================================================
# MYSQL / TRACCAR DATABASE
# =============================================================================
MYSQL_HOST=CHANGE_ME_MYSQL_HOST
MYSQL_PORT=3306
MYSQL_USER=CHANGE_ME_MYSQL_USER
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=traccar

# =============================================================================
# ROUTE CONFIGURATION
# =============================================================================
# Internal route ID used to filter vehicles in the database (tblvehiculo.idruta)
ROUTE_ID=08

# Route code expected by ATU's API (sent in the payload)
ATU_ROUTE_CODE=1247

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Express server port
APP_PORT=3000
